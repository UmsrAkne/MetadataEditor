<Window
    x:Class="MetadataEditor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:MetadataEditor.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MetadataEditor.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:viewModels="clr-namespace:MetadataEditor.ViewModels"
    Title="{Binding Title}"
    Width="960"
    Height="600"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <Window.Resources>
        <system:Double x:Key="CommonFontSize">15</system:Double>
        <SolidColorBrush x:Key="AppForegroundBrush" Color="Black" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveMetadataCommand}"
            Modifiers="Control" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ListBox
            Grid.Row="1"
            Grid.Column="0"
            AlternationCount="2"
            ItemsSource="{Binding ImageItems}"
            SelectedItem="{Binding SelectedImageItem}">

            <ListBox.InputBindings>
                <KeyBinding
                    Key="C"
                    Command="{Binding CopyToClipboardCommand}"
                    Modifiers="Control" />
                <KeyBinding
                    Key="V"
                    Command="{Binding PasteFromClipboardCommand}"
                    Modifiers="Control" />
            </ListBox.InputBindings>

            <b:Interaction.Behaviors>
                <behaviors:DropPngFilesToPathsBehavior />
            </b:Interaction.Behaviors>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ImageItem}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="8"
                                Height="8"
                                Margin="4,0,10,0"
                                VerticalAlignment="Center"
                                CornerRadius="4">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                <Setter Property="Background" Value="Coral" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding IsModified}" Value="False">
                                                <Setter Property="Background" Value="Transparent" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock
                                FontSize="{StaticResource CommonFontSize}"
                                Foreground="{StaticResource AppForegroundBrush}"
                                Text="{Binding FileName}" />
                        </StackPanel>

                        <Border
                            MinWidth="100"
                            Margin="35,3,10,2"
                            Padding="2,1"
                            BorderBrush="DarkGray"
                            BorderThickness="1"
                            CornerRadius="3">
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="{StaticResource CommonFontSize}"
                                Foreground="{StaticResource AppForegroundBrush}"
                                Text="{Binding Caption}" />
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0,5" />
                    <Style.Triggers>
                        <Trigger Property="ListBox.AlternationIndex" Value="0">
                            <Setter Property="Background" Value="SeaShell" />
                            <Setter Property="BorderBrush" Value="Silver" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

        </ListBox>

        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Padding="2"
            FontSize="{StaticResource CommonFontSize}"
            Foreground="{StaticResource AppForegroundBrush}"
            Text="{Binding SelectedImageItem.MetadataText, UpdateSourceTrigger=PropertyChanged}" />

        <ListBox
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            ItemsSource="{Binding ImageItems}"
            SelectedItem="{Binding SelectedImageItem}">

            <ListBox.InputBindings>
                <KeyBinding
                    Key="C"
                    Command="{Binding CopyToClipboardCommand}"
                    Modifiers="Control" />
                <KeyBinding
                    Key="V"
                    Command="{Binding PasteFromClipboardCommand}"
                    Modifiers="Control" />
            </ListBox.InputBindings>

            <b:Interaction.Behaviors>
                <behaviors:ScrollSelectedItemIntoViewBehavior />
            </b:Interaction.Behaviors>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ImageItem}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Image
                            Grid.Row="0"
                            Height="180"
                            Source="{Binding ImageSource}" />
                        <TextBlock
                            Grid.Row="1"
                            Width="240"
                            FontSize="{StaticResource CommonFontSize}"
                            Foreground="{StaticResource AppForegroundBrush}"
                            Text="{Binding FileName}"
                            TextAlignment="Center" />
                        <Border
                            Grid.Row="2"
                            Margin="5,2"
                            BorderBrush="DarkGray"
                            BorderThickness="1"
                            CornerRadius="3">
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding Caption}" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border
                                    x:Name="Bd"
                                    Padding="4"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="4">
                                    <ContentPresenter />
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- 通常選択 -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3B82F6" />
                                        <Setter TargetName="Bd" Property="Background" Value="#223B82F6" />
                                    </Trigger>

                                    <!-- マウスホバー -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#11000000" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Border
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="5">
            <Button
                Width="Auto"
                Padding="15,2"
                HorizontalAlignment="Right"
                Command="{Binding SaveMetadataCommand}"
                IsEnabled="{Binding SelectedImageItem.IsModified}">
                <Button.Content>
                    <TextBlock
                        FontSize="{StaticResource CommonFontSize}"
                        Foreground="{StaticResource AppForegroundBrush}"
                        Text="Save selected metadata (Ctrl + S)" />
                </Button.Content>
            </Button>
        </Border>

        <Border
            Grid.Row="4"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="5"
            Background="WhiteSmoke">
            <TextBlock
                FontSize="{StaticResource CommonFontSize}"
                Foreground="{StaticResource AppForegroundBrush}"
                Text="{Binding LogMessage}" />
        </Border>
    </Grid>

</Window>