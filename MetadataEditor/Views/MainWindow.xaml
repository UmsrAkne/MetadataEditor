<Window
    x:Class="MetadataEditor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:MetadataEditor.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MetadataEditor.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:viewModels="clr-namespace:MetadataEditor.ViewModels"
    Title="{Binding Title}"
    Width="960"
    Height="600"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <Window.Resources>
        <system:Double x:Key="CommonFontSize">15</system:Double>
        <!-- Dark theme brushes -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#232323" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2A2A2A" />
        <SolidColorBrush x:Key="AppForegroundBrush" Color="#EDEDED" />
        <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#B0B0B0" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3A3A3A" />
        <SolidColorBrush x:Key="AlternationBackgroundBrush" Color="#262626" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="AccentBackgroundBrush" Color="#223B82F6" />
        <SolidColorBrush x:Key="HoverBrush" Color="#22FFFFFF" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveMetadataCommand}"
            Modifiers="Control" />
    </Window.InputBindings>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="1" Grid.Column="0">

            <!-- ソート設定エリア -->
            <Border
                Padding="4"
                Background="{StaticResource PanelBackgroundBrush}"
                DockPanel.Dock="Top">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,5,0"
                        FontSize="{StaticResource CommonFontSize}"
                        Foreground="{StaticResource AppForegroundBrush}"
                        Text="Sort criteria : " />
                    <ComboBox
                        Width="220"
                        HorizontalAlignment="Left"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSortKey}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="SelectionChanged">
                                <b:InvokeCommandAction Command="{Binding SortCommand}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ComboBox>
                </StackPanel>
            </Border>

            <ListBox
                AlternationCount="2"
                Background="{StaticResource PanelBackgroundBrush}"
                ItemsSource="{Binding ImageItems}"
                SelectedItem="{Binding SelectedImageItem}">

                <ListBox.InputBindings>
                    <KeyBinding
                        Key="C"
                        Command="{Binding CopyToClipboardCommand}"
                        Modifiers="Control" />
                    <KeyBinding
                        Key="V"
                        Command="{Binding PasteFromClipboardCommand}"
                        Modifiers="Control" />
                </ListBox.InputBindings>

                <b:Interaction.Behaviors>
                    <behaviors:DropPngFilesToPathsBehavior />
                </b:Interaction.Behaviors>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ImageItem}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Row="0"
                                Grid.RowSpan="3"
                                Grid.Column="0"
                                Width="6"
                                Height="40"
                                Margin="4,0,10,0"
                                VerticalAlignment="Center"
                                CornerRadius="4">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                <Setter Property="Background" Value="Coral" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding IsModified}" Value="False">
                                                <Setter Property="Background" Value="Transparent" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                FontSize="{StaticResource CommonFontSize}"
                                Foreground="{StaticResource AppForegroundBrush}"
                                Text="{Binding FileName}" />

                            <Border
                                Grid.Row="1"
                                Grid.Column="1"
                                MinWidth="100"
                                Margin="35,3,10,2"
                                Padding="2,1"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="3">
                                <TextBox
                                    Background="{StaticResource ControlBackgroundBrush}"
                                    BorderThickness="0"
                                    FontSize="{StaticResource CommonFontSize}"
                                    Foreground="{StaticResource AppForegroundBrush}"
                                    Text="{Binding Caption}" />
                            </Border>

                            <ItemsControl
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="35,0,0,0"
                                ItemsSource="{Binding Diffs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:Diff}">
                                        <StackPanel Margin="0,5">
                                            <DockPanel>
                                                <TextBlock
                                                    Width="50"
                                                    Padding="2"
                                                    FontSize="{StaticResource CommonFontSize}"
                                                    Foreground="{StaticResource AppForegroundBrush}"
                                                    Text="Key : " />

                                                <TextBox
                                                    Padding="2"
                                                    Background="{StaticResource ControlBackgroundBrush}"
                                                    BorderThickness="0"
                                                    FontSize="{StaticResource CommonFontSize}"
                                                    Foreground="{StaticResource AppForegroundBrush}"
                                                    Text="{Binding Key, UpdateSourceTrigger=PropertyChanged, Delay=500}" />
                                            </DockPanel>

                                            <DockPanel>
                                                <TextBlock
                                                    Width="50"
                                                    Padding="2"
                                                    FontSize="{StaticResource CommonFontSize}"
                                                    Foreground="{StaticResource AppForegroundBrush}"
                                                    Text="Value : " />

                                                <TextBox
                                                    Margin="0,5,0,0"
                                                    Padding="2"
                                                    Background="{StaticResource ControlBackgroundBrush}"
                                                    BorderThickness="0"
                                                    FontSize="{StaticResource CommonFontSize}"
                                                    Foreground="{StaticResource AppForegroundBrush}"
                                                    Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, Delay=500}" />

                                            </DockPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0,5" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        x:Name="Bd"
                                        Padding="4"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding Background}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4">
                                        <ContentPresenter />
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <!-- 通常選択 -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBackgroundBrush}" />
                                        </Trigger>

                                        <!-- マウスホバー -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>



                            <Trigger Property="ListBox.AlternationIndex" Value="0">
                                <Setter Property="Background" Value="{StaticResource AlternationBackgroundBrush}" />
                            </Trigger>

                            <Trigger Property="ListBox.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

            </ListBox>

        </DockPanel>


        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox
                Grid.Row="0"
                Padding="2"
                AcceptsReturn="True"
                Background="{StaticResource ControlBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                FontSize="{StaticResource CommonFontSize}"
                Foreground="{StaticResource AppForegroundBrush}"
                Text="{Binding SelectedImageItem.MetadataText, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" />

            <Border
                Grid.Row="1"
                Background="{StaticResource AlternationBackgroundBrush}"
                DockPanel.Dock="Bottom">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Button
                        Grid.Row="0"
                        Width="200"
                        Margin="2"
                        Padding="4"
                        Command="{Binding AddDiffCommand}"
                        Content="Add diff" />

                    <ScrollViewer Grid.Row="1" MaxHeight="250">
                        <ItemsControl Margin="35,0,0,0" ItemsSource="{Binding SelectedImageItem.Diffs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Diff}">
                                    <StackPanel Margin="0,5">
                                        <DockPanel>
                                            <TextBlock
                                                Width="50"
                                                Padding="2"
                                                FontSize="{StaticResource CommonFontSize}"
                                                Foreground="{StaticResource AppForegroundBrush}"
                                                Text="Key : " />

                                            <TextBox
                                                Padding="2"
                                                Background="{StaticResource ControlBackgroundBrush}"
                                                BorderThickness="0"
                                                FontSize="{StaticResource CommonFontSize}"
                                                Foreground="{StaticResource AppForegroundBrush}"
                                                Text="{Binding Key, UpdateSourceTrigger=PropertyChanged, Delay=500}" />
                                        </DockPanel>

                                        <DockPanel>
                                            <TextBlock
                                                Width="50"
                                                Padding="2"
                                                FontSize="{StaticResource CommonFontSize}"
                                                Foreground="{StaticResource AppForegroundBrush}"
                                                Text="Value : " />

                                            <TextBox
                                                Margin="0,5,0,0"
                                                Padding="2"
                                                Background="{StaticResource ControlBackgroundBrush}"
                                                BorderThickness="0"
                                                FontSize="{StaticResource CommonFontSize}"
                                                Foreground="{StaticResource AppForegroundBrush}"
                                                Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, Delay=500}" />

                                        </DockPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>

            </Border>
        </Grid>

        <ListBox
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Background="{StaticResource PanelBackgroundBrush}"
            ItemsSource="{Binding ImageItems}"
            SelectedItem="{Binding SelectedImageItem}">

            <ListBox.InputBindings>
                <KeyBinding
                    Key="C"
                    Command="{Binding CopyToClipboardCommand}"
                    Modifiers="Control" />
                <KeyBinding
                    Key="V"
                    Command="{Binding PasteFromClipboardCommand}"
                    Modifiers="Control" />
            </ListBox.InputBindings>

            <b:Interaction.Behaviors>
                <behaviors:ScrollSelectedItemIntoViewBehavior />
            </b:Interaction.Behaviors>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ImageItem}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Image
                            Grid.Row="0"
                            Height="180"
                            Source="{Binding ImageSource}" />


                        <Border
                            Grid.Row="0"
                            Width="100"
                            Margin="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource AlternationBackgroundBrush}"
                            BorderBrush="DimGray"
                            BorderThickness="1"
                            CornerRadius="4"
                            Opacity="0.85">

                            <TextBlock
                                Padding="4,2"
                                HorizontalAlignment="Center"
                                FontSize="{StaticResource CommonFontSize}"
                                Foreground="{StaticResource AppForegroundBrush}"
                                Text="{Binding Resolution}" />
                        </Border>
                        <TextBlock
                            Grid.Row="1"
                            Width="240"
                            FontSize="{StaticResource CommonFontSize}"
                            Foreground="{StaticResource AppForegroundBrush}"
                            Text="{Binding FileName}"
                            TextAlignment="Center" />
                        <Border
                            Grid.Row="2"
                            Margin="5,2"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="3">
                            <TextBox
                                Background="{StaticResource ControlBackgroundBrush}"
                                BorderThickness="0"
                                Foreground="{StaticResource AppForegroundBrush}"
                                Text="{Binding Caption}" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border
                                    x:Name="Bd"
                                    Padding="4"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="4">
                                    <ContentPresenter />
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- 通常選択 -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBackgroundBrush}" />
                                    </Trigger>

                                    <!-- マウスホバー -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Border
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="5"
            Background="{StaticResource PanelBackgroundBrush}">
            <Button
                Width="Auto"
                Padding="15,2"
                HorizontalAlignment="Right"
                BorderBrush="{StaticResource BorderBrushDark}"
                Command="{Binding SaveMetadataCommand}"
                IsEnabled="{Binding SelectedImageItem.IsModified}">
                <Button.Content>
                    <TextBlock FontSize="{StaticResource CommonFontSize}" Text="Save selected metadata (Ctrl + S)" />
                </Button.Content>
            </Button>
        </Border>

        <Border
            Grid.Row="4"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="5"
            Background="{StaticResource PanelBackgroundBrush}">
            <TextBlock
                FontSize="{StaticResource CommonFontSize}"
                Foreground="{StaticResource AppForegroundBrush}"
                Text="{Binding LogMessage}" />
        </Border>
    </Grid>

</Window>